# --- Supabase REST (PostgREST) ---
# Project URL — e.g. https://xxxxx.supabase.co
SUPABASE_URL=
# Service-role key. Server-only; bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
# Anon key (optional, used as a fallback if service-role key is unset).
SUPABASE_ANON_KEY=

# 32+ char random string used to sign session JWTs.
# Generate one with: openssl rand -hex 32
AUTH_SECRET=

# Server-only internal API base. Never imported into client components.
API_URL=http://localhost:3000/api
